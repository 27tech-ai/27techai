# 27TechAI - Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER upload .env file to GitHub!

# ===========================================
# GITHUB CONFIGURATION
# ===========================================
GITHUB_USERNAME=your-github-username
GITHUB_REPO=your-repo-name
GITHUB_TOKEN=ghp_your-personal-access-token

# ===========================================
# AI API KEYS (Add at least one)
# ===========================================

# OpenRouter - Access to 100+ AI models (Recommended)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# OpenAI - GPT-3.5, GPT-4
OPENAI_API_KEY=sk-proj-your-openai-key

# Anthropic - Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Google AI - Gemini
GOOGLE_AI_API_KEY=your-google-ai-key

# HuggingFace - Open Source Models
HUGGINGFACE_API_KEY=hf-your-huggingface-token

# ===========================================
# NOTIFICATION SERVICES (Optional)
# ===========================================

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Discord Webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Twitter API Key
TWITTER_API_KEY=your-twitter-api-key

# ===========================================
# SITE CONFIGURATION
# ===========================================

# Your GitHub Pages URL
SITE_URL=https://yourusername.github.io/yourrepo

# Admin Password (for future features)
ADMIN_PASSWORD=your-secure-password
